
@model List<CartItemVM>

@{
    ViewData["Title"] = "Səbətim";
}

<section class="bg-light py-5">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <h1 class="h2 pb-4">Səbətim</h1>
            </div>
        </div>

        @if (Model == null || Model.Count == 0)
        {
            <div class="row">
                <div class="col-12 text-center py-5">
                    <i class="fas fa-shopping-cart fa-5x text-muted mb-3"></i>
                    <h3>Səbətiniz hazırda boşdur</h3>
                    <p class="text-muted">Görünür, hələ heç bir məhsul seçməmisiniz.</p>
                    <a href="/Shop/Index" class="btn btn-success btn-lg mt-3">Mağazaya Keç</a>
                </div>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-lg-8">
                    <div class="table-responsive">
                        <table class="table table-hover bg-white shadow-sm">
                            <thead class="bg-dark text-white">
                                <tr>
                                    <th scope="col">Məhsul</th>
                                    <th scope="col">Qiymət</th>
                                    <th scope="col">Say</th>
                                    <th scope="col">Cəmi</th>
                                    <th scope="col" class="text-center">Sil</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr class="align-middle" id="cart-row-@item.ProductId">
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="@item.ImageUrl" alt="@item.ProductName" style="width: 70px; height: 70px; object-fit: cover;" class="img-thumbnail me-3">
                                                <span class="fw-bold">@item.ProductName</span>
                                            </div>
                                        </td>
                                        <td>@item.Price.ToString("C")</td>
                                        <td>
                                            <div class="input-group input-group-sm" style="width: 120px;">
                                                <button class="btn btn-outline-dark btn-update-qty" type="button" data-id="@item.ProductId" data-change="-1">-</button>
                                                <input type="text" class="form-control text-center fw-bold qty-input-@item.ProductId" value="@item.Quantity" readonly>
                                                <button class="btn btn-outline-dark btn-update-qty" type="button" data-id="@item.ProductId" data-change="1">+</button>
                                            </div>
                                        </td>
                                        <td class="fw-bold item-total-@item.ProductId">@item.TotalPrice.ToString("C")</td>
                                        <td class="text-center">
                                            <form asp-controller="Cart" asp-action="RemoveFromCart" method="post">
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <button type="submit" class="btn btn-danger btn-sm">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-dark text-white">
                            <h5 class="mb-0">Sifarişin Xülasəsi</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-3">
                                <span>Ümumi Məhsul:</span>
                                <strong id="cart-summary-count">@Model.Sum(x => x.Quantity) ədəd</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-3">
                                <span>Çatdırılma:</span>
                                <strong class="text-success">Pulsuz</strong>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between mb-4">
                                <span class="h5">Yekun Məbləğ:</span>
                                <strong class="h5 text-danger" id="cart-summary-total">@Model.Sum(x => x.TotalPrice).ToString("C")</strong>
                            </div>

                            <a asp-controller="Cart" asp-action="Checkout" class="btn btn-success btn-lg w-100 mb-2">Sifarişi Rəsmiləşdir</a>
                            <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-dark w-100">Alış-verişə Davam Et</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>