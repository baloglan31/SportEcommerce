@model ForgotPasswordVM
@{
    ViewData["Title"] = "Şifrəni Unutdum";
}

<div class="container py-5 min-vh-50 d-flex justify-content-center align-items-center">
    <div class="col-md-6 col-lg-5 card shadow-sm border-0 p-4">
        <h3 class="text-center text-success fw-bold mb-3">Şifrəni Unutmusunuz?</h3>
        <p class="text-muted text-center mb-4">Narahat olmayın! Qeydiyyatdan keçdiyiniz email ünvanını yazın, sizə şifrəni yeniləmək üçün link göndərək.</p>

        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email Ünvanı</label>
                <input asp-for="Email" class="form-control form-control-lg" placeholder="adiniz@mail.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-success btn-lg w-100">Link Göndər</button>
        </form>
    </div>
</div>