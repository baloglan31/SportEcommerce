@model LoginVM

@{
    ViewData["Title"] = "Giriş";
}

<section class="bg-light py-5 min-vh-100 d-flex align-items-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card shadow-sm border-0 rounded-3">
                    <div class="card-body p-4 p-md-5">
                        <div class="text-center mb-4">
                            <h2 class="fw-bold text-success">Xoş Gəlmisiniz!</h2>
                            <p class="text-muted">Hesabınıza daxil olun</p>
                        </div>

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold text-center"></div>

                        <form asp-controller="Account" asp-action="Login" method="post">
                            <input type="hidden" asp-for="ReturnUrl" />

                            <div class="mb-3">
                                <label asp-for="UserName" class="form-label">İstifadəçi Adı (Username)</label>
                                <input asp-for="UserName" class="form-control form-control-lg" placeholder="İstifadəçi adınızı yazın..." />
                                <span asp-validation-for="UserName" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label">Şifrə</label>
                                <input asp-for="Password" class="form-control form-control-lg" placeholder="••••••••" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberMe">
                                    <label class="form-check-label text-muted" for="rememberMe">
                                        Məni xatırla
                                    </label>
                                </div>
                                <a href="#" class="text-success text-decoration-none small">Şifrəni unutmusunuz?</a>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-success btn-lg">Daxil Ol</button>
                            </div>
                        </form>

                        <div class="text-center mt-4">
                            <p class="mb-0">Hesabınız yoxdur? <a asp-controller="Account" asp-action="Register" class="text-success text-decoration-none fw-bold">Qeydiyyatdan keçin</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>