@model List<Order>

@{
    ViewData["Title"] = "Mənim Sifarişlərim";
}

<section class="bg-light py-5 min-vh-100">
    <div class="container">
        <div class="row mb-4">
            <div class="col-12">
                <h2 class="fw-bold"><i class="fas fa-box-open text-success me-2"></i>Mənim Sifarişlərim</h2>
                <p class="text-muted">Burada indiyə qədər etdiyiniz bütün sifarişlərin tarixçəsini görə bilərsiniz.</p>
            </div>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-info shadow-sm">
                Sizin hələ heç bir sifarişiniz yoxdur.
                <a href="/Shop/Index" class="alert-link">Mağazaya keçib alış-verişə başlayın!</a>
            </div>
        }
        else
        {
            <div class="accordion shadow-sm" id="ordersAccordion">
                @for (int i = 0; i < Model.Count; i++)
                {
                    var order = Model[i];
                    var headingId = $"heading{i}";
                    var collapseId = $"collapse{i}";

                    <div class="accordion-item border-0 border-bottom">
                        <h2 class="accordion-header" id="@headingId">
                            <button class="accordion-button collapsed bg-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                <div class="d-flex justify-content-between w-100 me-3">
                                    <span>Sifariş #@order.Id <small class="text-muted ms-2">(@order.OrderDate.ToString("dd.MM.yyyy HH:mm"))</small></span>
                                    <span class="text-danger">@order.TotalAmount.ToString("C")</span>
                                </div>
                            </button>
                        </h2>
                        <div id="@collapseId" class="accordion-collapse collapse bg-light" aria-labelledby="@headingId" data-bs-parent="#ordersAccordion">
                            <div class="accordion-body p-4">

                                <h6 class="fw-bold mb-3 text-success">Çatdırılma Məlumatları:</h6>
                                <p class="mb-1"><strong>Alıcı:</strong> @order.FullName</p>
                                <p class="mb-1"><strong>Əlaqə:</strong> @order.PhoneNumber</p>
                                <p class="mb-3"><strong>Ünvan:</strong> @order.Address</p>

                                <h6 class="fw-bold mb-3 mt-4 text-success">Alınan Məhsullar:</h6>
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered bg-white text-center align-middle">
                                        <thead class="table-dark">
                                            <tr>
                                                <th>Məhsul</th>
                                                <th>Qiymət</th>
                                                <th>Say</th>
                                                <th>Cəmi</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in order.OrderItems)
                                            {
                                                <tr>
                                                    <td class="text-start">@item.Product.Name</td>
                                                    <td>@item.Price.ToString("C")</td>
                                                    <td>@item.Quantity</td>
                                                    <td class="fw-bold">@((item.Price * item.Quantity).ToString("C"))</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>