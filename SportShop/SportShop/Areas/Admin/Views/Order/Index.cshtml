@model List<Order>

@{
    ViewData["Title"] = "Sifarişlər";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="fas fa-shopping-cart me-2"></i>Bütün Sifarişlər</h2>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark text-white">
                        <tr>
                            <th class="ps-4">Sifariş #</th>
                            <th>Müştəri (Ad/Soyad)</th>
                            <th>Tarix</th>
                            <th>Məbləğ</th>
                            <th class="text-center">Əməliyyat</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">#@order.Id</td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold">@order.FullName</span>
                                            <small class="text-muted">@order.Email</small>
                                        </div>
                                    </td>
                                    <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td class="fw-bold text-success">@order.TotalAmount.ToString("C")</td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-info text-white">
                                            <i class="fas fa-eye me-1"></i> Bax
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">Hələ heç bir sifariş yoxdur.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>